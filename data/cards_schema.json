{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://romaco-card-game/schema/card.json",
  "title": "Card",
  "description": "罵倒デッキ構築ゲームのカード1枚分のデータ定義。数値バランス自体はここに直書きせず、docs/04_balance_rules.md の基準値に沿って設定すること。",
  "type": "object",
  "required": ["id", "name", "type", "cost", "effects", "flavor"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][0-9]{2}$",
      "description": "カードID。攻撃=A、防御=D、強化=Bで始まる連番。"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 20 },
    "type": {
      "type": "string",
      "enum": ["attack", "defense", "buff"]
    },
    "attribute": {
      "type": ["string", "null"],
      "enum": ["煽り", "正論", "皮肉", "自虐からの逆転", null],
      "description": "攻撃カードのみ必須。防御・強化カードはnull。"
    },
    "cost": { "type": "integer", "minimum": 0, "maximum": 7 },
    "effects": {
      "type": "array",
      "minItems": 1,
      "description": "カード1枚が持つ効果のリスト。新しい効果種別を追加する場合、type の enum を拡張しコアロジック側に対応するハンドラを1つ追加すれば良く、既存カードのスキーマは変更不要。",
      "items": { "$ref": "#/$defs/effect" }
    },
    "flavor": { "type": "string", "maxLength": 60 }
  },
  "$defs": {
    "effect": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "damage",
            "damageIfWeakness",
            "damageIfSelfPrideBelowHalf",
            "prideHeal",
            "angerGain",
            "angerGainSelfPridePenalty",
            "blockNextDamage",
            "negateNextAttack",
            "revealOpponentHand",
            "revealWeaknessHint",
            "reduceOpponentAngerGain",
            "costReductionNextAttack",
            "costIncreaseNextTurn",
            "disableOpponentDefenseNextTurn",
            "reduceOpponentCostRecoveryNextTurn",
            "legendAwaken"
          ]
        },
        "value": {
          "type": "number",
          "description": "効果の数値パラメータ（ダメージ量、回復量、軽減量等）。数値の基準はdocs/04_balance_rules.mdに従う。"
        },
        "duration": {
          "type": "integer",
          "minimum": 1,
          "description": "効果の持続ターン数。単発効果の場合は省略可（暗黙的に1）。"
        }
      }
    }
  }
}
